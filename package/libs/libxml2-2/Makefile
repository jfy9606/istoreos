include $(TOPDIR)/rules.mk

PKG_NAME:=libxml2
PKG_VERSION:=2.13.6
PKG_RELEASE:=1

PKG_SOURCE:=$(PKG_NAME)-$(PKG_VERSION).tar.xz
PKG_SOURCE_URL:=@GNOME/libxml2/$(basename $(PKG_VERSION))
PKG_HASH:=f453480307524968f7a04ec65e64f2a83a825973bcd260a2e7691be82ae70c96

PKG_LICENSE:=MIT
PKG_LICENSE_FILES:=COPYING
PKG_CPE_ID:=cpe:/a:xmlsoft:libxml2

include $(INCLUDE_DIR)/package.mk
include $(INCLUDE_DIR)/cmake.mk
include $(INCLUDE_DIR)/nls.mk

define Package/libxml2-2
  SECTION:=libs
  CATEGORY:=Libraries
  TITLE:=Gnome XML library (ABI v2)
  URL:=http://xmlsoft.org/
  DEPENDS:=+libpthread +zlib $(ICONV_DEPENDS)
endef

define Package/libxml2-2/description
 A library for manipulating XML and HTML resources.  (ABI v2)
endef

CMAKE_HOST_OPTIONS += \
	-DBUILD_SHARED_LIBS=OFF \
	-DLIBXML2_WITH_C14N=ON \
	-DLIBXML2_WITH_CATALOG=OFF \
	-DLIBXML2_WITH_DEBUG=ON \
	-DLIBXML2_WITH_FTP=OFF \
	-DLIBXML2_WITH_HTML=ON \
	-DLIBXML2_WITH_HTTP=OFF \
	-DLIBXML2_WITH_ICONV=ON \
	-DLIBXML2_WITH_ICU=OFF \
	-DLIBXML2_WITH_ISO8859X=OFF \
	-DLIBXML2_WITH_LEGACY=OFF \
	-DLIBXML2_WITH_LZMA=OFF \
	-DLIBXML2_WITH_MEM_DEBUG=OFF \
	-DLIBXML2_WITH_MODULES=OFF \
	-DLIBXML2_WITH_OUTPUT=ON \
	-DLIBXML2_WITH_PATTERN=ON \
	-DLIBXML2_WITH_PROGRAMS=OFF \
	-DLIBXML2_WITH_PUSH=ON \
	-DLIBXML2_WITH_PYTHON=OFF \
	-DLIBXML2_WITH_READER=ON \
	-DLIBXML2_WITH_REGEXPS=ON \
	-DLIBXML2_WITH_RUN_DEBUG=OFF \
	-DLIBXML2_WITH_SAX1=ON \
	-DLIBXML2_WITH_SCHEMAS=ON \
	-DLIBXML2_WITH_SCHEMATRON=OFF \
	-DLIBXML2_WITH_TESTS=OFF \
	-DLIBXML2_WITH_THREADS=ON \
	-DLIBXML2_WITH_THREAD_ALLOC=OFF \
	-DLIBXML2_WITH_TREE=ON \
	-DLIBXML2_WITH_VALID=ON \
	-DLIBXML2_WITH_WRITER=ON \
	-DLIBXML2_WITH_XINCLUDE=ON \
	-DLIBXML2_WITH_XPATH=ON \
	-DLIBXML2_WITH_XPTR=ON \
	-DLIBXML2_WITH_XPTR_LOCS=ON \
	-DLIBXML2_WITH_ZLIB=ON

